# Copy this to .env before running install.sh or docker compose up
# Generated values are filled in automatically by install.sh

# PostgreSQL password — must be set; generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# Port exposed on the host (default: 8080)
PORT=8080

# Git repository URL — used by docker-update.sh to pull and rebuild
# Example: https://github.com/yourname/ares.git
GIT_REPO=

# Git branch to deploy from (default: main)
GIT_BRANCH=main
