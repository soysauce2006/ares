# Copy this to .env and fill in real values before deploying

# PostgreSQL password — set a strong random value
# Generate one with: openssl rand -hex 32
POSTGRES_PASSWORD=changeme

# Port the app listens on (default: 8080)
PORT=8080

# Git repository URL — used by update.sh to pull and rebuild
# Example: https://github.com/yourname/ares.git
GIT_REPO=

# Git branch to deploy from (default: main)
GIT_BRANCH=main
